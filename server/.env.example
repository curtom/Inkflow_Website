PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/inkflow
JWT_SECRET=change-me
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# 社区标签向量：国内通义千问（优先于 OpenAI）
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# 可选，text-embedding-v4：2048 / 1536 / 1024 / 768 / 512 / 256 / 128 / 64
# EMBEDDING_DIMENSIONS=1024

# 或使用 OpenAI（未配置 DASHSCOPE_API_KEY 时）
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

COMMUNITY_MATCH_MIN_SIMILARITY=0.35
# top1 与 top2 分差不足时不自动打标签，降低误判（建议 0.01~0.04）
COMMUNITY_MATCH_MIN_MARGIN=0.015
# 是否把作者已有标签拼进 embedding 文本（建议 false，避免人为标签干扰）
EMBEDDING_INCLUDE_EXISTING_TAGS=false
# 英文/中文轻量先验加权（建议 0.01~0.02）
COMMUNITY_LANGUAGE_PRIOR_BOOST=0.015

# 设为 true 时，每次社区标签分类会在服务端控制台打印 Top3 分组与分数
# COMMUNITY_CLASSIFIER_DEBUG=true
